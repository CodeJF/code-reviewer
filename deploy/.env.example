# Copy to deploy/.env on the server. Never commit the resulting file.
APP_ENV=production
APP_DOMAIN=ops.example.invalid
APP_URL=https://ops.example.invalid
CADDY_EMAIL=ops@example.com
POSTGRES_PASSWORD=replace-with-a-long-random-value
SESSION_SECRET=replace-with-at-least-32-random-characters
GRAFANA_ADMIN_PASSWORD=replace-with-a-separate-long-random-value
SL100_SECRET_DIR=/opt/sl100-secrets

# Production uses local accounts. Bootstrap the first administrator interactively.
AUTH_MODE=local
SESSION_COOKIE_NAME=sl100_session
SESSION_TTL_SECONDS=28800
INVITE_TTL_HOURS=24
RESET_TTL_MINUTES=30
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCK_MINUTES=15
DIAGNOSIS_RATE_LIMIT=10
DIAGNOSIS_RATE_WINDOW_SECONDS=600
DIAGNOSIS_MAX_ACTIVE=3
AI_ASSISTED_ENABLED=false
AGENT_MODEL_ID=claude-sonnet-4-6
AGENT_PROMPT_VERSION=controlled-ops-v1
AGENT_MAX_TURNS=3
AGENT_MAX_TOOL_CALLS=6
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_INPUT_TOKENS=32000
AGENT_MAX_OUTPUT_TOKENS=4096
AGENT_MAX_TOOL_RESULT_CHARS=20000

# Feishu is notification-only and optional; it never participates in login.
FEISHU_WEBHOOK_URL=
DIAGNOSIS_TTL_DAYS=90
AUDIT_TTL_DAYS=365
BACKUP_RETENTION_DAYS=14

# Optional image and package mirrors. Keep the official defaults unless the server needs regional mirrors.
PYTHON_IMAGE=python:3.13-slim
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2.10-alpine
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
GRAFANA_IMAGE=grafana/grafana:13.1.0
GRAFANA_PORT=53000
APT_DEBIAN_MIRROR=http://deb.debian.org/debian
APT_SECURITY_MIRROR=http://deb.debian.org/debian-security
PIP_INDEX_URL=https://pypi.org/simple
UV_DEFAULT_INDEX=https://pypi.org/simple
