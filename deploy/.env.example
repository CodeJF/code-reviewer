# Copy to deploy/.env on the server. Do not commit the resulting file.
APP_ENV=production
APP_DOMAIN=log.hassecurity.cn
APP_URL=https://log.hassecurity.cn
CADDY_EMAIL=ops@example.com
POSTGRES_PASSWORD=replace-with-a-long-random-value
SESSION_SECRET=replace-with-a-long-random-value
SL100_SECRET_DIR=/opt/sl100-diagnosis/secrets

# Company OIDC application. Register https://log.hassecurity.cn/api/auth/callback.
AUTH_MODE=oidc
OIDC_DISCOVERY_URL=https://id.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=replace-me
OIDC_CLIENT_SECRET=replace-me
OIDC_GROUPS_CLAIM=groups
OIDC_ADMIN_GROUPS=sl100-ops-admin
OIDC_ONCALL_GROUPS=sl100-oncall

# Leave blank to disable Feishu delivery until the team webhook is provisioned.
FEISHU_WEBHOOK_URL=
DIAGNOSIS_TTL_DAYS=90
AUDIT_TTL_DAYS=365
